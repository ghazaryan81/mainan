footer.fix-container
	.footer-top
		.__cell._1
			img.logo-without-symbol(src="./images/logo-without-symbol.svg" alt="" title="")
		p.__cell._2.descr
			| #{data.footer.descr}
		.__cell._3
			.soc-links
				a.soc-link._fb(href="#" target="_blank")
					+svg("fb")(viewBox="0 0 10 20" width="10" height="20")
				a.soc-link._inst(href="#" target="_blank")
					+svg("inst")(viewBox="0 0 46 46" width="20" height="20")
				a.soc-link._tw(href="#" target="_blank")
					+svg("tw")(viewBox="0 0 22 18" width="22" height="18")
	.footer-bottom
		| #{data.footer.bottomTxt}
